<%= form_with(model: provider_credential, local: true) do |form| %>
  <% if provider_credential.errors.any? %>
    <div class="ck-flash ck-flash--alert">
      <p class="ck-flash__title"><%= pluralize(provider_credential.errors.count, "problem") %> prevented this provider credential from being saved.</p>
      <ul class="ck-error-list">
        <% provider_credential.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="ck-card ck-form-card">
    <div class="ck-field">
      <%= form.label :provider, class: "ck-label" %>
      <%= form.select :provider, CompletionKit::ProviderCredential::PROVIDERS.map { |p| [CompletionKit::ProviderCredential::PROVIDER_LABELS[p] || p.titleize, p] }, {}, { class: "ck-input" } %>
    </div>

    <div class="ck-field">
      <%= form.label :api_key, "API key", class: "ck-label" %>
      <%= form.text_area :api_key, rows: 3, class: "ck-input ck-input--area ck-input--code", placeholder: "Paste the provider API key" %>
    </div>

    <div class="ck-field">
      <%= form.label :api_endpoint, "API endpoint", class: "ck-label" %>
      <%= form.text_field :api_endpoint, class: "ck-input", placeholder: "Only needed for llama-compatible or custom endpoints" %>
    </div>

    <div class="ck-actions">
      <%= link_to "Cancel", provider_credentials_path, class: ck_button_classes(:light, variant: :outline) %>
      <%= form.submit(provider_credential.persisted? ? "Save provider" : "Create provider", class: ck_button_classes(:dark)) %>
    </div>

    <% if provider_credential.persisted? %>
      <%= turbo_stream_from "completion_kit_provider_#{provider_credential.id}" %>

      <% models = CompletionKit::Model.where(provider: provider_credential.provider).active.order(:model_id) %>
      <% if models.any? || provider_credential.discovery_status.present? %>
        <div class="ck-form-card__footer">
          <div class="ck-form-card__footer-header">
            <%= render "discovery_status", provider_credential: provider_credential %>
            <%= button_to refresh_provider_credential_path(provider_credential), method: :post, class: "ck-icon-btn", title: "Refresh models" do %>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M13.836 2.477a.75.75 0 0 1 .75.75v3.182a.75.75 0 0 1-.75.75h-3.182a.75.75 0 0 1 0-1.5h1.37l-.84-.841a4.5 4.5 0 0 0-7.08.681.75.75 0 0 1-1.264-.808 6 6 0 0 1 9.44-.908l.84.84V3.227a.75.75 0 0 1 .75-.75Zm-.911 7.5A.75.75 0 0 1 13.199 11a6 6 0 0 1-9.44.908l-.84-.84v1.68a.75.75 0 0 1-1.5 0V9.567a.75.75 0 0 1 .75-.75h3.182a.75.75 0 0 1 0 1.5h-1.37l.84.841a4.5 4.5 0 0 0 7.08-.681.75.75 0 0 1 1.024-.274Z" clip-rule="evenodd"/></svg>
            <% end %>
          </div>

          <% if models.any? %>
            <details class="ck-model-list-details">
              <summary class="ck-label" style="cursor: pointer; user-select: none;">Available models (<%= models.count %>)</summary>
              <div class="ck-model-list">
                <% models.each do |m| %>
                  <span class="ck-model-list__item">
                    <%= m.display_name || m.model_id %>
                    <% if m.supports_generation && m.supports_judging %>
                      <span class="ck-model-list__badge">gen + judge</span>
                    <% elsif m.supports_generation %>
                      <span class="ck-model-list__badge">gen</span>
                    <% elsif m.supports_judging %>
                      <span class="ck-model-list__badge">judge</span>
                    <% end %>
                  </span>
                <% end %>
              </div>
            </details>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
