<% @provider_credentials.each do |pc| %>
  <%= turbo_stream_from "completion_kit_provider_#{pc.id}" %>
<% end %>

<section class="ck-page-header">
  <div>
    <h1 class="ck-title">Settings</h1>
    <p class="ck-lead">API keys for LLM providers. These are used for both generating prompt completions and running judge evaluations.</p>
  </div>
  <div class="ck-actions">
    <%= link_to "New provider", new_provider_credential_path, class: ck_button_classes(:dark) %>
  </div>
</section>

<% if @provider_credentials.any? %>
  <% default_endpoints = {"openai" => "https://api.openai.com", "anthropic" => "https://api.anthropic.com"} %>
  <div class="ck-provider-list">
    <% @provider_credentials.each do |provider_credential| %>
      <% masked_key = provider_credential.api_key.present? ? "#{provider_credential.api_key[0..6]}#{'•' * 12}#{provider_credential.api_key[-4..]}" : "—" %>
      <a href="<%= edit_provider_credential_path(provider_credential) %>" class="ck-provider-card">
        <div class="ck-provider-card__header">
          <span class="ck-provider-card__name"><%= provider_credential.display_provider %></span>
          <span class="ck-provider-card__key"><%= masked_key %></span>
        </div>

        <div class="ck-provider-card__meta">
          <span><%= provider_credential.api_endpoint.presence || default_endpoints[provider_credential.provider] %></span>
          <span><%= provider_credential.prompt_count %> prompts</span>
          <span><%= provider_credential.judge_count %> judges</span>
          <span><%= provider_credential.last_used_at ? "Used #{time_ago_in_words(provider_credential.last_used_at)} ago" : "Never used" %></span>
        </div>

        <%= render "discovery_status", provider_credential: provider_credential %>
      </a>
    <% end %>
  </div>
<% else %>
  <div class="ck-empty">
    No providers yet. Add one to start running prompts.
  </div>
<% end %>
