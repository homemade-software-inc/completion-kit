<section class="ck-page-header">
  <div>
    <h1 class="ck-title">Providers</h1>
    <p class="ck-lead">API credentials for generation and scoring.</p>
  </div>
  <div class="ck-actions">
    <%= link_to "New provider", new_provider_credential_path, class: ck_button_classes(:dark) %>
  </div>
</section>

<% if @provider_credentials.any? %>
  <div class="ck-list">
    <% @provider_credentials.each do |provider_credential| %>
      <section class="ck-card">
        <div class="ck-split">
          <div class="ck-stack">
            <div class="ck-inline">
              <h2 class="ck-card-title"><%= provider_credential.display_provider %></h2>
              <span class="<%= ck_badge_classes(provider_credential.configured? ? :high : :failed) %>"><%= provider_credential.configured? ? "Connected" : "Not connected" %></span>
            </div>
            <p class="ck-meta-copy"><%= provider_credential.api_endpoint.presence || "Default endpoint" %></p>
          </div>
          <div class="ck-actions">
            <%= link_to "Edit", edit_provider_credential_path(provider_credential), class: ck_button_classes(:light, variant: :outline) %>
          </div>
        </div>
      </section>
    <% end %>
  </div>
<% else %>
  <div class="ck-empty">
    No providers yet. Add one to start running prompts.
  </div>
<% end %>
