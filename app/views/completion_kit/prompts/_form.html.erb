<%= form_with(model: prompt, local: true) do |form| %>
  <% if prompt.errors.any? %>
    <div class="ck-flash ck-flash--alert">
      <p class="ck-flash__title"><%= pluralize(prompt.errors.count, "problem") %> prevented this prompt from being saved.</p>
      <ul class="ck-error-list">
        <% prompt.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="ck-card ck-form-card">
    <div class="ck-field">
      <%= form.label :name, "Name", class: "ck-label" %>
      <%= form.text_field :name, class: "ck-input", placeholder: "Support summary" %>
    </div>

    <div class="ck-field">
      <%= form.label :description, class: "ck-label" %>
      <%= form.text_area :description, rows: 3, class: "ck-input ck-input--area", placeholder: "Short note about this prompt." %>
    </div>

    <div class="ck-field">
      <%= form.label :template, "Prompt text", class: "ck-label" %>
      <%= form.text_area :template, rows: 12, class: "ck-input ck-input--area ck-input--code", placeholder: "Summarize {{content}} for {{audience}}" %>
      <p class="ck-hint">Use <code>{{variable}}</code>. Match your dataset column names.</p>
    </div>

    <div class="ck-field">
      <%= form.label :llm_model, "Generation model", class: "ck-label" %>
      <%= form.select :llm_model, CompletionKit::Prompt.available_models.map { |model| [model[:name], model[:id]] }, {}, { class: "ck-input" } %>
    </div>

    <div class="ck-field">
      <%= form.label :assessment_model, "Assessment model", class: "ck-label" %>
      <%= form.select :assessment_model, CompletionKit::Prompt.available_models.map { |model| [model[:name], model[:id]] }, {}, { class: "ck-input" } %>
    </div>

    <div class="ck-field">
      <%= form.label :metric_group_id, "Metric group", class: "ck-label" %>
      <%= form.collection_select :metric_group_id, @metric_groups, :id, :name, { include_blank: "Choose a metric group" }, { class: "ck-input" } %>
      <p class="ck-hint">This decides how results are scored.</p>
    </div>

    <div class="ck-field">
      <%= form.label :review_guidance, "Review notes", class: "ck-label" %>
      <%= form.text_area :review_guidance, rows: 4, class: "ck-input ck-input--area", placeholder: "Optional notes for scoring this prompt." %>
      <p class="ck-hint">Optional.</p>
    </div>

    <div class="ck-actions">
      <%= link_to "Cancel", prompts_path, class: ck_button_classes(:light, variant: :outline) %>
      <%= form.submit(prompt.persisted? ? "Save prompt" : "Create prompt", class: ck_button_classes(:dark)) %>
    </div>
  </div>
<% end %>
