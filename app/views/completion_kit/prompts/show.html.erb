<ol class="ck-breadcrumb">
  <li><%= link_to "Prompts", prompts_path %></li>
  <li><%= @prompt.name %></li>
</ol>

<section class="ck-page-header">
  <div>
    <div class="ck-inline">
      <h1 class="ck-title"><%= @prompt.name %></h1>
      <span class="ck-chip"><%= @prompt.llm_model %></span>
    </div>
    <% if @prompt.description.present? %>
      <p class="ck-meta-copy"><%= @prompt.description %></p>
    <% end %>
    <div class="ck-endpoint">
      <code class="ck-endpoint__url" id="prompt_endpoint"><%= request.base_url %><%= api_v1_prompt_path(@prompt.slug) %></code>
      <button type="button" class="ck-icon-btn" title="Copy endpoint" onclick="navigator.clipboard.writeText(document.getElementById('prompt_endpoint').textContent)"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" width="14" height="14"><path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z"/><path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"/></svg></button>
    </div>
  </div>

  <div class="ck-actions">
    <% current = @prompt.family_versions.find_by(current: true) || @prompt %>
    <%= link_to "Edit", edit_prompt_path(current), class: ck_button_classes(:light, variant: :outline) %>
    <%= link_to "Run test", new_run_path(prompt_id: current.id), class: ck_button_classes(:dark) %>
  </div>
</section>

<section>
  <div class="ck-prompt-preview__header">
    <p class="ck-kicker">Prompt</p>
    <% judged_run = @runs.select { |r| r.prompt_id == @prompt.id && r.status == "completed" }.find { |r| r.responses.joins(:reviews).exists? } %>
    <% if judged_run %>
      <%= button_to "Suggest improvements", suggest_run_path(judged_run), method: :post, class: ck_button_classes(:light, variant: :outline) + " ck-button--sm", form_class: "inline-block" %>
    <% end %>
  </div>
  <pre class="ck-code ck-code--dark"><%= @prompt.template %></pre>
</section>

<% versions = @prompt.family_versions %>
<% if versions.size > 1 %>
  <section class="ck-card--spaced">
    <p class="ck-kicker">Versions</p>
    <table class="ck-results-table" style="margin-top: 0.5rem;">
      <thead>
        <tr>
          <th>Version</th>
          <th>Model</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% versions.each do |v| %>
          <tr>
            <td><strong>v<%= v.version_number %></strong></td>
            <td><span class="ck-chip ck-chip--soft"><%= v.llm_model %></span></td>
            <td class="ck-meta-copy"><%= time_ago_in_words(v.created_at) %> ago</td>
            <td>
              <% if v.current? %>
                <span class="ck-chip">Current</span>
              <% else %>
                <%= button_to "Publish", publish_prompt_path(v), method: :post, class: "ck-chip ck-chip--publish", form_class: "inline-block" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
<% end %>

<% if @runs.any? %>
  <section class="ck-card--spaced">
    <p class="ck-kicker">Runs</p>

    <table class="ck-results-table" style="margin-top: 0.5rem;">
      <thead>
        <tr>
          <th>Run</th>
          <th>Version</th>
          <th>Responses</th>
          <th>Avg score</th>
          <th>Metrics</th>
          <th>When</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @runs.each do |run| %>
          <tr onclick="window.location='<%= run_path(run) %>'" style="cursor: pointer;">
            <td><span class="ck-run-name"><span class="<%= ck_run_dot(run) %>"></span><strong><%= run.name %></strong></span></td>
            <td><span class="ck-chip ck-chip--soft">v<%= run.prompt.version_number %></span></td>
            <td><%= run.responses.size %></td>
            <td>
              <% avg = run.avg_score %>
              <% if avg %>
                <span class="<%= ck_badge_classes(ck_score_kind(avg)) %>"><%= avg %></span>
              <% else %>
                &mdash;
              <% end %>
            </td>
            <td>
              <% metrics = run.metric_averages %>
              <% if metrics.any? %>
                <div class="ck-metric-bar ck-metric-bar--compact">
                  <% metrics.each do |m| %>
                    <span class="ck-metric-pip ck-metric-pip--<%= ck_score_kind(m[:avg]) %>">
                      <span class="ck-metric-pip__bar"></span>
                      <span class="ck-metric-pip__label"><%= m[:name] %> <strong><%= m[:avg] %></strong></span>
                    </span>
                  <% end %>
                </div>
              <% else %>
                &mdash;
              <% end %>
            </td>
            <td class="ck-meta-copy"><%= time_ago_in_words(run.created_at) %> ago</td>
            <td class="ck-results-table__arrow">&rarr;</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
<% end %>

