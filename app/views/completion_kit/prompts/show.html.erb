<ol class="ck-breadcrumb">
  <li><%= link_to "Prompts", prompts_path %></li>
  <li><%= @prompt.name %></li>
</ol>

<section class="ck-page-header">
  <div>
    <div class="ck-inline">
      <h1 class="ck-title"><%= @prompt.display_name %></h1>
      <span class="ck-chip"><%= @prompt.llm_model %></span>
      <% if @prompt.current? %>
        <span class="<%= ck_badge_classes(:high) %>">Current</span>
      <% end %>
    </div>
    <% if @prompt.description.present? %>
      <p class="ck-lead"><%= @prompt.description %></p>
    <% end %>
  </div>

  <div class="ck-actions">
    <% unless @prompt.current? %>
      <%= button_to "Publish", publish_prompt_path(@prompt), method: :post, class: ck_button_classes(:light, variant: :outline), form_class: "inline-block" %>
    <% end %>
    <%= button_to "New version", new_version_prompt_path(@prompt), method: :post, class: ck_button_classes(:light, variant: :outline), form_class: "inline-block" %>
    <%= link_to "Edit", edit_prompt_path(@prompt), class: ck_button_classes(:light, variant: :outline) %>
    <%= link_to "New run", new_test_run_path(prompt_id: @prompt.id), class: ck_button_classes(:dark) %>
  </div>
</section>

<section class="ck-grid ck-grid--sidebar">
  <div class="ck-card">
    <p class="ck-kicker">Prompt</p>
    <pre class="ck-code ck-code--dark"><%= @prompt.template %></pre>
  </div>

  <div class="ck-card">
    <p class="ck-kicker">Details</p>

    <dl class="ck-stat-list">
      <div class="ck-stat-row">
        <dt>Judge model</dt>
        <dd><%= @prompt.assessment_model %></dd>
      </div>
      <div class="ck-stat-row">
        <dt>Metrics</dt>
        <dd><%= @prompt.metric_group&.name || "Default" %></dd>
      </div>
      <div class="ck-stat-row">
        <dt>Runs</dt>
        <dd><%= @prompt.test_runs.count %></dd>
      </div>
      <div class="ck-stat-row">
        <dt>Published</dt>
        <dd><%= @prompt.published_at&.strftime("%Y-%m-%d") || "Draft" %></dd>
      </div>
    </dl>

    <% if @prompt.variables.any? %>
      <p class="ck-minor-label" style="margin-top: 0.75rem;">Variables</p>
      <div class="ck-chip-row">
        <% @prompt.variables.each do |variable| %>
          <span class="ck-chip ck-chip--soft"><%= variable %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<% if @prompt.assessment_metrics.any? %>
<section class="ck-card ck-card--spaced">
  <p class="ck-kicker">Metrics</p>

  <div class="ck-list ck-list--compact">
    <% @prompt.assessment_metrics.each do |metric| %>
      <div class="ck-item">
        <div class="ck-stack">
          <p class="ck-item-title"><%= link_to metric.name, metric_path(metric), class: "ck-link" %></p>
          <% if metric.criteria.present? %>
            <p class="ck-copy"><%= metric.criteria %></p>
          <% end %>
        </div>
      </div>

      <div class="ck-rubric-display">
        <% metric.rubric_bands_for_form.each do |band| %>
          <div class="ck-rubric-row ck-rubric-row--display">
            <div class="ck-rubric-row__range">
              <span class="ck-rubric-range"><%= band["stars"] %> ★</span>
            </div>
            <div class="ck-rubric-row__fields">
              <div class="ck-field ck-field--tight">
                <p class="ck-label">Description</p>
                <p class="ck-copy"><%= band["description"] %></p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
<% end %>

<% if @family_versions.length > 1 %>
<section class="ck-card ck-card--spaced">
  <p class="ck-kicker">Versions</p>

  <div class="ck-list ck-list--compact">
    <% @family_versions.each do |version| %>
      <div class="ck-item">
        <div>
          <p class="ck-item-title"><%= link_to version.display_name, prompt_path(version), class: "ck-link" %></p>
          <p class="ck-meta-copy"><%= version.llm_model %> · <%= pluralize(version.test_runs.count, "run") %></p>
        </div>
        <div class="ck-actions">
          <% unless version.current? %>
            <%= button_to "Publish", publish_prompt_path(version), method: :post, class: ck_button_classes(:light, variant: :outline), form_class: "inline-block" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
<% end %>

<% if @prompt.test_runs.any? %>
<section class="ck-card ck-card--spaced">
  <p class="ck-kicker">Runs</p>

  <div class="ck-list ck-list--compact">
    <% @prompt.test_runs.order(created_at: :desc).each do |test_run| %>
      <div class="ck-item">
        <div>
          <p class="ck-item-title"><%= link_to test_run.name, test_run_path(test_run), class: "ck-link" %></p>
          <p class="ck-meta-copy"><%= test_run.created_at.strftime("%Y-%m-%d %H:%M") %> · <%= pluralize(test_run.test_results.count, "result") %> · <%= test_run.status %></p>
        </div>
      </div>
    <% end %>
  </div>
</section>
<% end %>
