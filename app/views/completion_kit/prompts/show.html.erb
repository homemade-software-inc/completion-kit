<ol class="ck-breadcrumb">
  <li><%= link_to "Prompts", prompts_path %></li>
  <li><%= @prompt.name %></li>
</ol>

<section class="ck-page-header">
  <div>
    <div class="ck-inline">
      <h1 class="ck-title"><%= @prompt.name %></h1>
      <span class="<%= ck_badge_classes(@prompt.current? ? :high : :pending) %>">v<%= @prompt.version_number %><%= " · current" if @prompt.current? %></span>
      <span class="ck-chip"><%= @prompt.llm_model %></span>
    </div>
  </div>

  <div class="ck-actions">
    <%= link_to "Edit", edit_prompt_path(@prompt), class: ck_button_classes(:light, variant: :outline) %>
    <%= button_to "New version", new_version_prompt_path(@prompt), method: :post, class: ck_button_classes(:light, variant: :outline), form_class: "inline-block" %>
    <%= link_to "Run test", new_run_path(prompt_id: @prompt.id), class: ck_button_classes(:dark) %>
  </div>
</section>

<section>
  <p class="ck-kicker">Template</p>
  <pre class="ck-code ck-code--dark"><%= @prompt.template %></pre>
</section>

<% if @runs.any? %>
  <section class="ck-card--spaced">
    <p class="ck-kicker">Runs</p>

    <table class="ck-results-table" style="margin-top: 0.5rem;">
      <thead>
        <tr>
          <th>Run</th>
          <th>Responses</th>
          <th>Avg score</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @runs.each do |run| %>
          <tr onclick="window.location='<%= run_path(run) %>'" style="cursor: pointer;">
            <td><strong><%= run.name %></strong></td>
            <td><%= run.responses.size %></td>
            <td>
              <% avg = run.avg_score %>
              <% if avg %>
                <span class="<%= ck_badge_classes(ck_score_kind(avg)) %>"><%= avg %></span>
              <% else %>
                &mdash;
              <% end %>
            </td>
            <td class="ck-results-table__arrow">&rarr;</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
<% end %>

<% if @family_versions.length > 1 %>
  <section class="ck-card--spaced">
    <p class="ck-kicker">Versions</p>

    <div class="ck-inline" style="margin-top: 0.5rem; gap: 0.5rem;">
      <% @family_versions.each do |version| %>
        <% if version.id == @prompt.id %>
          <span class="ck-chip ck-chip--soft">v<%= version.version_number %></span>
        <% else %>
          <%= link_to "v#{version.version_number}", prompt_path(version), class: "ck-chip" %>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
