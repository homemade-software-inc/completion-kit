<section class="ck-page-header">
  <div>
    <h1 class="ck-title">Prompts</h1>
    <p class="ck-lead">A prompt is the instruction sent to the model. Prompts can include variables like <code>{{customer_name}}</code> that get filled from each dataset row.</p>
  </div>
  <div class="ck-actions">
    <%= link_to "New prompt", new_prompt_path, class: ck_button_classes(:dark) %>
    <%= link_to "Metrics", metrics_path, class: ck_button_classes(:light, variant: :outline) %>
    <%= link_to "Metric groups", metric_groups_path, class: ck_button_classes(:light, variant: :outline) %>
    <%= link_to "Runs", test_runs_path, class: ck_button_classes(:light, variant: :outline) %>
  </div>
</section>

<% if @prompts.any? %>
  <div class="ck-list">
    <% @prompts.each do |prompt| %>
      <section class="ck-card">
        <div class="ck-split">
          <div class="ck-stack">
            <div class="ck-inline">
              <h2 class="ck-card-title"><%= link_to prompt.name, prompt_path(prompt), class: "ck-link" %></h2>
              <span class="ck-chip"><%= prompt.version_label %></span>
              <span class="ck-chip"><%= prompt.llm_model %></span>
              <span class="ck-chip ck-chip--soft">Assess with <%= prompt.assessment_model %></span>
            </div>

            <p class="ck-copy"><%= prompt.description.presence || "No description yet. Add one so other people know what this prompt is for." %></p>

            <div class="ck-chip-row">
              <% prompt.variables.each do |variable| %>
                <span class="ck-chip ck-chip--soft"><%= variable %></span>
              <% end %>
            </div>

            <% if prompt.variables.empty? %>
              <p class="ck-note">No <code>{{variables}}</code> yet. Add them if you want each CSV row to change the prompt input.</p>
            <% else %>
              <p class="ck-note">CSV headers should match these variable names.</p>
            <% end %>

            <p class="ck-note">
              Metric group:
              <strong><%= prompt.metric_group&.name || "Legacy single-metric fallback" %></strong>
            </p>
          </div>

          <div class="ck-actions">
            <%= link_to "Open", prompt_path(prompt), class: ck_button_classes(:dark) %>
            <%= link_to "Edit", edit_prompt_path(prompt), class: ck_button_classes(:amber, variant: :outline) %>
            <%= link_to "New CSV run", new_test_run_path(prompt_id: prompt.id), class: ck_button_classes(:green) %>
            <%= button_to "Delete", prompt_path(prompt), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: ck_button_classes(:red, variant: :outline), form_class: "inline-block" %>
          </div>
        </div>
      </section>
    <% end %>
  </div>
<% else %>
  <div class="ck-empty">
    No prompts yet. Create one, then attach a dataset and run it.
  </div>
<% end %>
