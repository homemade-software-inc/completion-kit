<section class="ck-page-header">
  <div>
    <h1 class="ck-title">Prompts</h1>
    <p class="ck-lead">Templates sent to LLMs for completion. Each prompt is versioned so you can track changes and compare results over time.</p>
  </div>
  <div class="ck-actions">
    <%= link_to "New prompt", new_prompt_path, class: ck_button_classes(:dark) %>
  </div>
</section>

<% if @prompts.any? %>
  <table class="ck-results-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Model</th>
        <th>Runs</th>
        <th>Last run</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @prompts.each do |prompt| %>
        <tr onclick="window.location='<%= prompt_path(prompt) %>'" style="cursor: pointer;">
          <td><strong><%= prompt.name %></strong></td>
          <td><span class="ck-chip"><%= prompt.llm_model %></span></td>
          <td><%= prompt.runs.size %></td>
          <td>
            <% last_run = prompt.runs.max_by(&:created_at) %>
            <% if last_run %>
              <%= time_ago_in_words(last_run.created_at) %> ago
            <% else %>
              &mdash;
            <% end %>
          </td>
          <td class="ck-results-table__arrow">&rarr;</td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="ck-empty">
    No prompts yet. Create one to get started.
  </div>
<% end %>
