<section class="ck-page-header">
  <div>
    <h1 class="ck-title">New prompt</h1>
    <p class="ck-lead">Write the prompt, add any variables it needs, choose the generation and review models, and decide which metric group should score the results.</p>
  </div>
  <div class="ck-actions">
    <%= link_to "All prompts", prompts_path, class: ck_button_classes(:light, variant: :outline) %>
    <%= link_to "Metrics", metrics_path, class: ck_button_classes(:light, variant: :outline) %>
    <%= link_to "Metric groups", metric_groups_path, class: ck_button_classes(:light, variant: :outline) %>
  </div>
</section>

<%= render "form", prompt: @prompt %>
