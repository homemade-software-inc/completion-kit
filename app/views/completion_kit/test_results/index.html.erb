<section class="ck-page-header">
  <div>
    <h1 class="ck-title">Review results for <%= @test_run.name %></h1>
    <p class="ck-lead">Sort and filter the results.</p>
  </div>
  <div class="ck-actions">
    <%= link_to "Back to run", test_run_path(@test_run), class: ck_button_classes(:light, variant: :outline) %>
  </div>
</section>

<section class="ck-card">
  <div class="ck-filter-grid">
    <div>
      <p class="ck-minor-label">Filter</p>
      <div class="ck-toolbar">
        <%= link_to "All", test_run_test_results_path(@test_run, filter: "all", sort: params[:sort]), class: params[:filter].blank? || params[:filter] == "all" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
        <%= link_to "High", test_run_test_results_path(@test_run, filter: "high_quality", sort: params[:sort]), class: params[:filter] == "high_quality" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
        <%= link_to "Medium", test_run_test_results_path(@test_run, filter: "medium_quality", sort: params[:sort]), class: params[:filter] == "medium_quality" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
        <%= link_to "Low", test_run_test_results_path(@test_run, filter: "low_quality", sort: params[:sort]), class: params[:filter] == "low_quality" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
        <%= link_to "Unscored", test_run_test_results_path(@test_run, filter: "no_score", sort: params[:sort]), class: params[:filter] == "no_score" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
      </div>
    </div>

    <div>
      <p class="ck-minor-label">Sort</p>
      <div class="ck-toolbar">
        <%= link_to "Best first", test_run_test_results_path(@test_run, sort: "score_desc", filter: params[:filter]), class: params[:sort].blank? || params[:sort] == "score_desc" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
        <%= link_to "Worst first", test_run_test_results_path(@test_run, sort: "score_asc", filter: params[:filter]), class: params[:sort] == "score_asc" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
        <%= link_to "Newest", test_run_test_results_path(@test_run, sort: "created_desc", filter: params[:filter]), class: params[:sort] == "created_desc" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
        <%= link_to "Oldest", test_run_test_results_path(@test_run, sort: "created_asc", filter: params[:filter]), class: params[:sort] == "created_asc" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
      </div>
    </div>
  </div>
</section>

<% if @test_results.any? %>
  <div class="ck-grid ck-grid--cards">
    <% @test_results.each do |result| %>
      <article class="ck-result-card">
        <div class="ck-split ck-split--tight">
          <h2 class="ck-card-title">Result #<%= result.id %></h2>
          <span class="<%= ck_badge_classes(ck_score_kind(result.quality_score)) %>">
            <%= result.quality_score ? "Score #{result.quality_score}" : "Pending" %>
          </span>
        </div>

        <% if result.human_score.present? %>
          <p class="ck-meta-copy">Human score: <strong><%= result.human_score %></strong> by <%= result.human_reviewer_name.presence || "reviewer" %></p>
        <% end %>

        <div class="ck-stack">
          <div>
            <p class="ck-minor-label">Input row</p>
            <pre class="ck-code"><%= JSON.parse(result.input_data).to_json(pretty: true) rescue result.input_data %></pre>
          </div>

          <div>
            <p class="ck-minor-label">Model output</p>
            <pre class="ck-code"><%= result.output_text %></pre>
          </div>

          <% if result.expected_output.present? %>
            <div>
              <p class="ck-minor-label">Expected output</p>
              <pre class="ck-code"><%= result.expected_output %></pre>
            </div>
          <% end %>
        </div>

        <div class="ck-actions">
          <%= link_to "View details", test_run_test_result_path(@test_run, result), class: ck_button_classes(:blue, variant: :outline) %>
        </div>
      </article>
    <% end %>
  </div>
<% else %>
  <div class="ck-empty">
    No results match the current filter.
  </div>
<% end %>
