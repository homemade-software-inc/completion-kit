<section class="ck-page-header">
  <div>
    <p class="ck-step">Setup</p>
    <h1 class="ck-title"><%= @metric_group.name %></h1>
    <p class="ck-lead"><%= @metric_group.description.presence || "No description yet." %></p>
  </div>
  <div class="ck-actions">
    <%= link_to "Edit", edit_metric_group_path(@metric_group), class: ck_button_classes(:amber, variant: :outline) %>
    <%= link_to "All groups", metric_groups_path, class: ck_button_classes(:light, variant: :outline) %>
  </div>
</section>

<section class="ck-card">
  <p class="ck-kicker">Metrics in this group</p>
  <% if @metric_group.metrics.any? %>
    <div class="ck-list ck-list--compact">
      <% @metric_group.metrics.each do |metric| %>
        <div class="ck-item">
          <div>
            <p class="ck-item-title"><%= metric.name %></p>
            <p class="ck-copy"><%= metric.description.presence || "No description yet." %></p>
          </div>
          <div class="ck-actions">
            <%= link_to "Open metric", metric_path(metric), class: ck_button_classes(:dark) %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="ck-copy">No metrics in this group yet.</p>
  <% end %>
</section>
