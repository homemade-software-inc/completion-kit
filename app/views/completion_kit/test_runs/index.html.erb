<section class="ck-page-header">
  <div>
    <h1 class="ck-title">Runs</h1>
    <p class="ck-lead">Each run is a dataset attached to a prompt.</p>
  </div>
  <div class="ck-actions">
    <%= link_to "New run", new_test_run_path, class: ck_button_classes(:dark) %>
  </div>
</section>

<% if @test_runs.any? %>
  <div class="ck-list">
    <% @test_runs.each do |test_run| %>
      <section class="ck-card">
        <div class="ck-split">
          <div class="ck-stack">
            <div class="ck-inline">
              <h2 class="ck-card-title"><%= link_to test_run.name, test_run_path(test_run), class: "ck-link" %></h2>
              <span class="<%= ck_badge_classes(test_run.status.to_s.presence&.to_sym) %>"><%= test_run.status %></span>
              <% if test_run.respond_to?(:source) && test_run.source == "eval_dsl" %>
                <span class="ck-chip ck-chip--soft">eval</span>
              <% end %>
            </div>
            <p class="ck-copy">Prompt: <%= link_to test_run.prompt.display_name, prompt_path(test_run.prompt), class: "ck-link" %></p>
            <p class="ck-meta-copy"><%= test_run.created_at.strftime("%Y-%m-%d %H:%M") %> · <%= pluralize(test_run.csv_data.to_s.lines.count - 1, "CSV row") %> · <%= pluralize(test_run.test_results.count, "result") %></p>
          </div>

          <div class="ck-actions">
            <%= link_to "Open", test_run_path(test_run), class: ck_button_classes(:dark) %>
            <%= button_to "Delete", test_run_path(test_run), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: ck_button_classes(:red, variant: :outline), form_class: "inline-block" %>
          </div>
        </div>
      </section>
    <% end %>
  </div>
<% else %>
  <div class="ck-empty">
    No runs yet.
  </div>
<% end %>
