<%# Form partial for test run creation and editing %>
<%= form_with(model: test_run, local: true) do |form| %>
  <% if test_run.errors.any? %>
    <div class="ck-flash ck-flash--alert">
      <p class="ck-flash__title"><%= pluralize(test_run.errors.count, "problem") %> prevented this CSV run from being saved.</p>
      <ul class="ck-error-list">
        <% test_run.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="ck-card ck-form-card">
    <div class="ck-field">
      <%= form.label :prompt_id, "Prompt version", class: "ck-label" %>
      <%= form.collection_select :prompt_id, @prompts, :id, :display_name, { selected: params[:prompt_id] }, { class: "ck-input" } %>
      <p class="ck-hint">Runs stay attached to the exact prompt version you choose here.</p>
    </div>

    <div class="ck-field">
      <%= form.label :name, "Run name", class: "ck-label" %>
      <%= form.text_field :name, class: "ck-input", placeholder: "Regression batch for support summaries" %>
    </div>

    <div class="ck-field">
      <%= form.label :csv_data, "CSV test cases", class: "ck-label" %>
      <%= form.text_area :csv_data, rows: 12, class: "ck-input ck-input--area ck-input--code", placeholder: "Paste your CSV here" %>
      <p class="ck-hint">Header names should match the prompt variables. <code>expected_output</code> is optional.</p>
      <pre class="ck-code">
input,expected_output
"Summarize this paragraph...","A concise summary..."
"Explain the concept of...","The concept refers to..."</pre>
    </div>

    <div class="ck-actions">
      <%= link_to "Cancel", test_runs_path, class: ck_button_classes(:light, variant: :outline) %>
      <%= form.submit(test_run.persisted? ? "Save run" : "Create run", class: ck_button_classes(:dark)) %>
    </div>
  </div>
<% end %>
