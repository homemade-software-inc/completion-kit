<% unscored_count = @test_run.test_results.where(quality_score: nil).count %>

<ol class="ck-breadcrumb">
  <li><%= link_to "Runs", test_runs_path %></li>
  <li><%= @test_run.name %></li>
</ol>

<section class="ck-page-header">
  <div>
    <div class="ck-inline">
      <h1 class="ck-title"><%= @test_run.name %></h1>
      <span class="<%= ck_badge_classes(@test_run.status.to_s.to_sym) %>"><%= @test_run.status %></span>
      <% if @test_run.respond_to?(:source) && @test_run.source == "eval_dsl" %>
        <span class="ck-chip ck-chip--soft">eval</span>
      <% end %>
    </div>
    <p class="ck-meta-copy"><%= link_to @test_run.prompt.display_name, prompt_path(@test_run.prompt), class: "ck-link" %> · <%= @test_run.prompt.llm_model %> · <%= @test_run.created_at.strftime("%Y-%m-%d %H:%M") %></p>
  </div>

  <div class="ck-actions">
    <%= link_to "Edit", edit_test_run_path(@test_run), class: ck_button_classes(:light, variant: :outline) %>
    <% if @test_run.test_results.any? %>
      <%= link_to "Results", test_run_test_results_path(@test_run), class: ck_button_classes(:light, variant: :outline) %>
      <%= button_to "Run AI review", evaluate_test_run_path(@test_run), method: :post, class: ck_button_classes(:light, variant: :outline), form_class: "inline-block" %>
    <% end %>
    <%= button_to "Generate outputs", run_test_run_path(@test_run), method: :post, class: ck_button_classes(:dark), form_class: "inline-block" %>
  </div>
</section>

<section class="ck-grid ck-grid--sidebar">
  <div class="ck-card">
    <p class="ck-kicker">Dataset</p>
    <pre class="ck-code ck-code--dark"><%= @test_run.csv_data.to_s.lines.first(10).join %><% if @test_run.csv_data.to_s.lines.count > 10 %>...<% end %></pre>
  </div>

  <div class="ck-card">
    <p class="ck-kicker">Summary</p>
    <dl class="ck-stat-list">
      <div class="ck-stat-row">
        <dt>CSV rows</dt>
        <dd><%= [@test_run.csv_data.to_s.lines.count - 1, 0].max %></dd>
      </div>
      <div class="ck-stat-row">
        <dt>Outputs</dt>
        <dd><%= @test_run.test_results.count %></dd>
      </div>
      <div class="ck-stat-row">
        <dt>Scored</dt>
        <dd><%= @test_run.test_results.where.not(quality_score: nil).count %></dd>
      </div>
      <div class="ck-stat-row">
        <dt>Unscored</dt>
        <dd><%= unscored_count %></dd>
      </div>
    </dl>
  </div>
</section>

<% if @test_results.any? %>
  <section class="ck-card ck-card--spaced">
    <div class="ck-split">
      <p class="ck-kicker">Results</p>
      <div class="ck-toolbar">
        <%= link_to "Best first", test_run_path(@test_run, sort: "score_desc"), class: params[:sort].blank? || params[:sort] == "score_desc" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
        <%= link_to "Worst first", test_run_path(@test_run, sort: "score_asc"), class: params[:sort] == "score_asc" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
      </div>
    </div>

    <div class="ck-grid ck-grid--cards">
      <% @test_results.each do |result| %>
        <article class="ck-result-card">
          <div class="ck-split ck-split--tight">
            <h3 class="ck-card-title"><%= link_to "Result ##{result.id}", test_run_test_result_path(@test_run, result), class: "ck-link" %></h3>
            <span class="<%= ck_badge_classes(ck_score_kind(result.quality_score)) %>">
              <%= result.quality_score ? "Score #{result.quality_score}" : "Pending" %>
            </span>
          </div>

          <div class="ck-stack">
            <div>
              <p class="ck-minor-label">Input</p>
              <pre class="ck-code"><%= result.input_data %></pre>
            </div>

            <div>
              <p class="ck-minor-label">Output</p>
              <pre class="ck-code"><%= result.output_text %></pre>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  </section>
<% else %>
  <div class="ck-empty ck-empty--spaced">
    No results yet. Generate outputs to see results here.
  </div>
<% end %>
