<%= turbo_stream_from "completion_kit_run_#{@run.id}" %>

<ol class="ck-breadcrumb">
  <li><%= link_to "Prompts", prompts_path %></li>
  <li><%= link_to @run.prompt.name, prompt_path(@run.prompt) %></li>
  <li><span class="ck-run-name"><span class="<%= ck_run_dot(@run) %>"></span><%= @run.name %></span></li>
</ol>

<section class="ck-page-header">
  <div>
    <h1 class="ck-title"><span class="ck-run-name"><span class="<%= ck_run_dot(@run) %>"></span><%= @run.name %></span></h1>
  </div>

  <div class="ck-actions">
    <%= link_to "Edit", edit_run_path(@run), class: ck_button_classes(:light, variant: :outline) %>
    <% if @run.status == "pending" || (@run.status == "completed" && @run.responses.empty?) %>
      <%= button_to "Start", generate_run_path(@run), method: :post, class: ck_button_classes(:dark), form_class: "inline-block" %>
    <% end %>
    <% if @run.status == "completed" && @run.responses.any? && !@run.judge_configured? %>
      <%= link_to "Judge responses", edit_run_path(@run), class: ck_button_classes(:dark) %>
    <% end %>
    <% if @run.judge_configured? && @run.status == "completed" %>
      <%= button_to "Re-judge", judge_run_path(@run), method: :post, class: ck_button_classes(:light, variant: :outline), form_class: "inline-block" %>
    <% end %>
    <%= button_to run_path(@run), method: :delete, form_class: "inline-block", class: "ck-icon-btn", title: "Delete run", data: { turbo_confirm: "Delete this run and all its responses?" } do %><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg><% end %>
  </div>
</section>

<div class="ck-run-config">
  <div class="ck-run-config__row">
    <span class="ck-run-config__key">Model</span>
    <span class="ck-chip"><%= @run.prompt.llm_model %></span>
  </div>
  <div class="ck-run-config__row">
    <span class="ck-run-config__key">Dataset</span>
    <% if @run.dataset %>
      <%= link_to @run.dataset.name, dataset_path(@run.dataset), class: "ck-link" %>
    <% else %>
      <span class="ck-run-config__none">none — prompt runs as-is</span>
    <% end %>
  </div>
  <div class="ck-run-config__row">
    <span class="ck-run-config__key">Judge</span>
    <% if @run.judge_configured? %>
      <span><%= @run.judge_model %></span>
    <% elsif @run.judge_model.present? %>
      <span><%= @run.judge_model %></span>
      <span class="ck-run-config__warn">
        provider not configured —
        <%= link_to "set up #{CompletionKit::ApiConfig.provider_for_model(@run.judge_model) || 'provider'}", new_provider_credential_path, class: "ck-link" %>
      </span>
    <% else %>
      <span class="ck-run-config__none">none</span>
    <% end %>
  </div>
  <div class="ck-run-config__row">
    <span class="ck-run-config__key">Metrics</span>
    <% if @run.metrics.any? %>
      <span><span class="ck-run-config__none">(<%= @run.metrics.count %> metrics)</span></span>
    <% else %>
      <span class="ck-run-config__none">none</span>
    <% end %>
  </div>
  <% unless @run.judge_configured? %>
    <div class="ck-run-config__note">
      <% if !@run.judge_model.present? && !@run.metrics.any? %>
        Responses only — no judge and metrics configured.
      <% elsif !@run.judge_model.present? %>
        Responses only — no judge model selected.
      <% elsif @run.judge_model.present? && !@run.judge_configured? && !@run.metrics.any? %>
        Responses only — judge provider not configured and no metrics selected.
      <% elsif @run.judge_model.present? && !@run.judge_configured? %>
        Responses only — judge provider not configured.
      <% elsif !@run.metrics.any? %>
        Responses only — no metrics to score against.
      <% end %>
    </div>
  <% end %>
</div>

<% if @run.dataset %>
  <details class="ck-details">
    <summary class="ck-details__summary">Dataset preview</summary>
    <pre class="ck-code ck-code--dark"><%= @run.dataset.csv_data.to_s.lines.first(10).join %><% if @run.dataset.csv_data.to_s.lines.count > 10 %>...<% end %></pre>
  </details>
<% end %>

<%= render "progress", run: @run %>

<% judged = @responses.any? { |r| r.reviewed? } %>

<% if judged %>
  <div class="ck-toolbar" style="margin-top: 1.5rem;">
    <%= link_to "Best first", run_path(@run, sort: "score_desc"), class: params[:sort].blank? || params[:sort] == "score_desc" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
    <%= link_to "Worst first", run_path(@run, sort: "score_asc"), class: params[:sort] == "score_asc" ? ck_button_classes(:dark) : ck_button_classes(:light, variant: :outline) %>
  </div>
<% end %>

<div id="run_responses">
  <% @responses.each_with_index do |response, idx| %>
    <%= render "response_row", run: @run, response: response, index: idx + 1 %>
  <% end %>
  <% if @responses.empty? %>
    <div class="ck-empty ck-empty--spaced">
      No responses yet. Start the run to generate responses.
    </div>
  <% end %>
</div>
