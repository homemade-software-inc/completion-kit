<ol class="ck-breadcrumb">
  <li><%= link_to "Metrics", metrics_path %></li>
  <li><%= @metric.name %></li>
</ol>

<section class="ck-page-header">
  <div>
    <h1 class="ck-title"><%= @metric.name %></h1>
    <% if @metric.description.present? %>
      <p class="ck-lead"><%= @metric.description %></p>
    <% end %>
  </div>
  <div class="ck-actions">
    <%= link_to "Edit", edit_metric_path(@metric), class: ck_button_classes(:light, variant: :outline) %>
  </div>
</section>

<% if @metric.guidance_text.present? %>
<section class="ck-card">
  <p class="ck-kicker">Guidance</p>
  <div class="ck-note-box"><%= @metric.guidance_text %></div>
</section>
<% end %>

<section class="ck-card ck-card--spaced">
  <p class="ck-kicker">Rubric</p>
  <div class="ck-rubric-display">
    <% @metric.rubric_bands_for_form.each do |band| %>
      <div class="ck-rubric-row ck-rubric-row--display">
        <div class="ck-rubric-row__range">
          <span class="ck-rubric-range"><%= band["range"] %></span>
        </div>
        <div class="ck-rubric-row__fields">
          <div class="ck-field ck-field--tight">
            <p class="ck-label">Criteria</p>
            <p class="ck-copy"><%= band["criteria"] %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</section>
