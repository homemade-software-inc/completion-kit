<section class="ck-page-header">
  <div>
    <p class="ck-step">Setup</p>
    <h1 class="ck-title"><%= @metric.name %></h1>
    <p class="ck-lead"><%= @metric.description.presence || "No description yet." %></p>
  </div>
  <div class="ck-actions">
    <%= link_to "Edit", edit_metric_path(@metric), class: ck_button_classes(:amber, variant: :outline) %>
    <%= link_to "All metrics", metrics_path, class: ck_button_classes(:light, variant: :outline) %>
  </div>
</section>

<section class="ck-card">
  <p class="ck-kicker">Assessment guidance</p>
  <div class="ck-note-box"><%= @metric.guidance_text.presence || "No extra guidance for this metric." %></div>
</section>

<section class="ck-card ck-card--spaced">
  <p class="ck-kicker">Rubric</p>
  <div class="ck-rubric-display">
    <% @metric.rubric_bands_for_form.each do |band| %>
      <div class="ck-rubric-row ck-rubric-row--display">
        <div class="ck-rubric-row__range">
          <span class="ck-rubric-range"><%= band["range"] %></span>
        </div>
        <div class="ck-rubric-row__fields">
          <div class="ck-field ck-field--tight">
            <p class="ck-label">Criteria</p>
            <p class="ck-copy"><%= band["criteria"] %></p>
          </div>
          <div class="ck-field ck-field--tight">
            <p class="ck-label">Reasoning cue</p>
            <p class="ck-copy"><%= band["reason"] %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</section>
