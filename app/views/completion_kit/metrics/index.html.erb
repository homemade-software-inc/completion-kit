<section class="ck-page-header">
  <div>
    <h1 class="ck-title">Metrics</h1>
    <p class="ck-lead">Scoring dimensions used by the judge model to evaluate responses. Each metric defines what to assess, the evaluation steps, and a rubric for star ratings.</p>
  </div>
  <div class="ck-actions">
    <%= link_to "Criteria", criteria_path, class: ck_button_classes(:light, variant: :outline) %>
    <%= link_to "New metric", new_metric_path, class: ck_button_classes(:dark) %>
  </div>
</section>

<% if @metrics.any? %>
  <table class="ck-results-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Criteria</th>
        <th>Criteria</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @metrics.each do |metric| %>
        <tr onclick="window.location='<%= metric_path(metric) %>'" style="cursor: pointer;">
          <td><strong><%= metric.name %></strong></td>
          <td><%= truncate(metric.criteria.to_s, length: 80) %></td>
          <td>
            <% c = metric.criterias.first %>
            <%= c&.name || "&mdash;".html_safe %>
          </td>
          <td class="ck-results-table__arrow">&rarr;</td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="ck-empty">No metrics yet.</div>
<% end %>
