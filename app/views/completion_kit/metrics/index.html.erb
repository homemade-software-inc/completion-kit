<section class="ck-page-header">
  <div>
    <h1 class="ck-title">Metrics</h1>
    <p class="ck-lead">Each metric is one way to score a result.</p>
  </div>
  <div class="ck-actions">
    <%= link_to "New metric", new_metric_path, class: ck_button_classes(:dark) %>
    <%= link_to "Groups", metric_groups_path, class: ck_button_classes(:light, variant: :outline) %>
  </div>
</section>

<% if @metrics.any? %>
  <div class="ck-list">
    <% @metrics.each do |metric| %>
      <section class="ck-card">
        <div class="ck-split">
          <div class="ck-stack">
            <h2 class="ck-card-title"><%= link_to metric.name, metric_path(metric), class: "ck-link" %></h2>
            <% if metric.description.present? %>
              <p class="ck-copy"><%= metric.description %></p>
            <% end %>
          </div>
          <div class="ck-actions">
            <%= link_to "Edit", edit_metric_path(metric), class: ck_button_classes(:light, variant: :outline) %>
            <%= link_to "Open", metric_path(metric), class: ck_button_classes(:dark) %>
          </div>
        </div>
      </section>
    <% end %>
  </div>
<% else %>
  <div class="ck-empty">No metrics yet.</div>
<% end %>
