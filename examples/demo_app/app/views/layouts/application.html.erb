<!DOCTYPE html>
<html>
  <head>
    <title>CompletionKit Demo</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="min-h-screen bg-amber-50 text-stone-950 antialiased">
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute left-[-8rem] top-[-6rem] h-72 w-72 rounded-full bg-orange-300/30 blur-3xl"></div>
      <div class="absolute right-[-10rem] top-20 h-80 w-80 rounded-full bg-cyan-300/20 blur-3xl"></div>
      <div class="absolute bottom-[-8rem] left-1/3 h-72 w-72 rounded-full bg-emerald-200/25 blur-3xl"></div>
    </div>

    <header class="relative z-10 border-b border-stone-900/10 bg-white/70 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-10">
        <div class="space-y-1">
          <%= link_to root_path, class: "inline-flex items-center gap-3" do %>
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-stone-950 text-sm font-black tracking-[0.2em] text-white">CK</span>
            <span>
              <span class="block text-[11px] font-semibold uppercase tracking-[0.28em] text-stone-500">Demo Host App</span>
              <span class="block text-lg font-semibold tracking-tight text-stone-950">CompletionKit</span>
            </span>
          <% end %>
        </div>

        <nav class="hidden items-center gap-3 md:flex">
          <%= link_to "Home", root_path, class: "rounded-full px-4 py-2 text-sm font-medium text-stone-700 transition hover:bg-stone-900 hover:text-white" %>
          <%= link_to "Engine UI", "/completion_kit", class: "rounded-full bg-stone-950 px-4 py-2 text-sm font-medium text-white transition hover:bg-stone-800" %>
          <%= link_to "Prompts", "/completion_kit/prompts", class: "rounded-full px-4 py-2 text-sm font-medium text-stone-700 transition hover:bg-stone-900 hover:text-white" %>
          <%= link_to "Test Runs", "/completion_kit/test_runs", class: "rounded-full px-4 py-2 text-sm font-medium text-stone-700 transition hover:bg-stone-900 hover:text-white" %>
        </nav>
      </div>
    </header>

    <main class="relative z-10 mx-auto max-w-7xl px-6 py-10 lg:px-10 lg:py-14">
      <%= yield %>
    </main>
  </body>
</html>
