<!DOCTYPE html>
<html>
  <head>
    <title>CompletionKit Demo</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  </head>

  <body class="min-h-screen bg-[#080b14] text-slate-200 antialiased" style="font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;">
    <header class="sticky top-0 z-10 border-b border-slate-800 bg-[#080b14]/85 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-10">
        <%= link_to root_path, class: "inline-flex items-center gap-2 no-underline" do %>
          <span class="text-sm font-bold tracking-widest text-cyan-400" style="font-family: 'JetBrains Mono', monospace;">
            <span class="text-slate-600">></span> COMPLETIONKIT
          </span>
        <% end %>

        <nav class="hidden items-center gap-2 md:flex">
          <%= link_to "Home", root_path, class: "rounded-md border border-transparent px-3 py-1.5 text-xs font-medium tracking-wider uppercase text-slate-400 transition hover:border-cyan-400 hover:text-cyan-400", style: "font-family: 'JetBrains Mono', monospace;" %>
          <%= link_to "Engine UI", "/completion_kit", class: "rounded-md bg-cyan-400 px-3 py-1.5 text-xs font-medium tracking-wider uppercase text-[#080b14] transition hover:bg-cyan-300", style: "font-family: 'JetBrains Mono', monospace;" %>
          <%= link_to "Prompts", "/completion_kit/prompts", class: "rounded-md border border-transparent px-3 py-1.5 text-xs font-medium tracking-wider uppercase text-slate-400 transition hover:border-cyan-400 hover:text-cyan-400", style: "font-family: 'JetBrains Mono', monospace;" %>
          <%= link_to "Runs", "/completion_kit/test_runs", class: "rounded-md border border-transparent px-3 py-1.5 text-xs font-medium tracking-wider uppercase text-slate-400 transition hover:border-cyan-400 hover:text-cyan-400", style: "font-family: 'JetBrains Mono', monospace;" %>
        </nav>
      </div>
    </header>

    <main class="relative z-10 mx-auto max-w-7xl px-6 py-10 lg:px-10 lg:py-14">
      <%= yield %>
    </main>
  </body>
</html>
