<!DOCTYPE html>
<html>
<head>
  <title>CompletionKit</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "completion_kit/application", media: "all" %>
</head>
<body class="ck-app">
  <header class="ck-topbar">
    <div class="ck-wrap ck-topbar__inner">
      <%= link_to "CompletionKit", root_path, class: "ck-brand" %>

      <nav class="ck-nav">
        <%= link_to "Prompts", completion_kit.prompts_path, class: "ck-btn ck-btn--light ck-btn--outline" %>
        <%= link_to "Metrics", completion_kit.metrics_path, class: "ck-btn ck-btn--light ck-btn--outline" %>
        <%= link_to "Datasets", completion_kit.datasets_path, class: "ck-btn ck-btn--light ck-btn--outline" %>
        <%= link_to "Runs", completion_kit.runs_path, class: "ck-btn ck-btn--light ck-btn--outline" %>
        <%= link_to "Settings", completion_kit.provider_credentials_path, class: "ck-btn ck-btn--light ck-btn--outline" %>
      </nav>
    </div>
  </header>

  <main class="ck-main">
    <div class="ck-wrap">
      <% flash.each do |type, message| %>
        <div class="ck-flash <%= type.to_s == "notice" ? "ck-flash--notice" : "ck-flash--alert" %>">
          <%= message %>
        </div>
      <% end %>

      <%= yield %>
    </div>
  </main>
</body>
</html>
